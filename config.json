{
  "api": {
    "api_key": "PUT_YOUR_GEMINI_API_KEY_HERE"
  },
  "gpio": {
    "button_gpio": 23,
    "led_gpio": 25,
    "button_bounce_sec": 0.03
  },
  "led": {
    "speaking_fade_in_seconds": 0.35,
    "speaking_fade_out_seconds": 0.35,
    "error_blink_on_seconds": 0.08,
    "error_blink_off_seconds": 0.08,
    "error_blink_count": 6,
    "wake_wait_pulse_seconds": 1.2
  },
  "audio": {
    "send_rate": 16000,
    "recv_rate": 24000,
    "chunk": 2048,
    "alsa_in_dev": "default",
    "alsa_out_dev": "default"
  },
  "gemini": {
    "model": "gemini-2.5-flash-native-audio-preview-12-2025",
    "system_instruction": "Respond briefly and concisely.",
    "voice_name": "Kore"
  },
  "debug": {
    "print_transcript": true,
    "print_audio_stats": true
  },
  "wake_word": {
    "keyword": "gemini",
    "vosk_model_path": "vosk-model-small-en-us-0.15",
    "listen_rate": 16000,
    "listen_chunk": 4000,
    "silence_timeout_seconds": 1.0,
    "speech_rms_threshold": 450,
    "max_record_seconds": 12.0
  }
